# ============================================
# TokenMachine Development Environment
# 当前机器 - 单卡 RTX 4090
# ============================================

# Database
POSTGRES_PASSWORD=dev_password_123

# API Security
SECRET_KEY=dev_secret_key_for_local_development
API_KEY_PREFIX=tmachine_dev_

# Grafana
GRAFANA_PASSWORD=admin

# Environment
ENVIRONMENT=development
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# GPU Configuration (RTX 4090)
GPU_MEMORY_UTILIZATION=0.85
MAX_MODEL_LEN=8192
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.85

# Workers
WORKER_BASE_PORT=8001
WORKER_START_TIMEOUT=300

# Monitoring
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# Storage
MODEL_STORAGE_PATH=/var/lib/tokenmachine/models
LOG_PATH=/var/log/tokenmachine

# CORS (allow all for development)
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# SSL (disabled for development)
SSL_ENABLED=false

# Feature Flags
USE_MOCK_DATA=true
