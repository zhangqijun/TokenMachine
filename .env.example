# Database
DATABASE_URL=postgresql://inferx:inferx_password@localhost:5432/inferx

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Security
SECRET_KEY=your-secret-key-change-this-in-production
API_KEY_PREFIX=inferx_sk_

# Storage
MODEL_STORAGE_PATH=/var/lib/inferx/models
LOG_PATH=/var/log/inferx

# GPU
GPU_MEMORY_UTILIZATION=0.9
MAX_MODEL_LEN=4096

# Workers
WORKER_BASE_PORT=8001
WORKER_START_TIMEOUT=300

# Monitoring
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# vLLM
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.9

# Environment
ENVIRONMENT=development
DEBUG=true
