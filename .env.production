# ============================================
# TokenMachine Production Environment
# Bowser - RTX 3090
# 生产环境 - 有 HTTPS 证书和路由器配置
# ============================================

# Database
POSTGRES_PASSWORD=prod_secure_password_change_me

# API Security
SECRET_KEY=prod_secret_key_generate_with_openssl_rand_hex_32
API_KEY_PREFIX=tmachine_sk_

# Grafana
GRAFANA_PASSWORD=prod_grafana_secure_password

# Environment
ENVIRONMENT=production
DEBUG=false

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# GPU Configuration (RTX 3090 with driver issues)
GPU_MEMORY_UTILIZATION=0.85
MAX_MODEL_LEN=4096
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_DISABLE_CUSTOM_ALL_REDUCE=true  # Workaround for driver issues

# Workers
WORKER_BASE_PORT=8001
WORKER_START_TIMEOUT=300

# Monitoring
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# Storage
MODEL_STORAGE_PATH=/var/lib/tokenmachine/models
LOG_PATH=/var/log/tokenmachine

# CORS (restrictive for production)
CORS_ORIGINS=https://zhangqijun.cn,https://10.0.0.147:8443
CORS_ALLOW_CREDENTIALS=true

# SSL (enabled for production)
SSL_ENABLED=true
SSL_CERT_PATH=/etc/nginx/ssl/zhangqijun.cn.crt
SSL_KEY_PATH=/etc/nginx/ssl/zhangqijun.cn.key
SSL_CHAIN_PATH=/etc/nginx/ssl/root_bundle.crt

# Network configuration
PUBLIC_DOMAIN=zhangqijun.cn
PUBLIC_IP=10.0.0.147

# Router ports
HTTPS_PORT=8443
HTTP_PORT=8080
GRAFANA_PORT=3001
PROMETHEUS_PORT=9091

# Feature Flags
USE_MOCK_DATA=false
