# ============================================
# TokenMachine Test Environment
# Bulbaser - 7卡 NVIDIA RTX 3090
# 多节点分布式部署
# ============================================

# Database
POSTGRES_PASSWORD=test_tokenmachine_secure_2025

# API Security
SECRET_KEY=test_secret_key_change_before_prod_$(openssl rand -hex 32)
API_KEY_PREFIX=tmachine_test_

# Grafana
GRAFANA_PASSWORD=test_grafana_admin_2025

# Environment
ENVIRONMENT=test
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# GPU Configuration (7x RTX 3090)
GPU_MEMORY_UTILIZATION=0.9
MAX_MODEL_LEN=4096
VLLM_TENSOR_PARALLEL_SIZE=2
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.9

# Workers
WORKER_BASE_PORT=8001
WORKER_START_TIMEOUT=300
WORKER_COUNT=7

# Multi-node Configuration
NODE_ID=node1
NODE_LIST=node1:10.0.0.100,node2:10.0.0.101,node3:10.0.0.102

# Monitoring
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# Storage
MODEL_STORAGE_PATH=/var/lib/tokenmachine/models
LOG_PATH=/var/log/tokenmachine

# CORS (restrictive for test)
CORS_ORIGINS=http://localhost:3000,http://10.0.0.100:3000
CORS_ALLOW_CREDENTIALS=true

# SSL (disabled for test)
SSL_ENABLED=false

# Test-specific settings
ALLOW_TEST_MODELS=true
ENABLE_PERFORMANCE_LOGGING=true

# Feature Flags
USE_MOCK_DATA=true
